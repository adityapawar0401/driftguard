DRIFTGUARD_PORT=4100
DRIFTGUARD_MEMORY_BACKEND=local
DRIFTGUARD_DATA_FILE=./data/driftguard-store.json
DRIFTGUARD_EVERMIND_WRITE_RAW_EVENTS=false
EVERMIND_API_BASE_URL=https://api.evermind.ai
# EVEROS_API_BASE_URL=https://api.evermind.ai
EVERMIND_USER_ID=driftguard-demo
# EVEROS_USER_ID=driftguard-demo
# EVEROS_API_KEY=your-evermind-api-key
# EVERMIND_API_KEY=your-evermind-api-key
# EVERMIND_STRICT=false
DRIFTGUARD_USE_OLLAMA_ADVISORY=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
